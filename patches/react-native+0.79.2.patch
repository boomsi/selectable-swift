 - (void)handleLongPress:(UILongPressGestureRecognizer *)gesture
 {
+  if (gesture.state != UIGestureRecognizerStateBegan) {
+    return;
+  }
+
+  // DEBUG: 红色方块验证 handleLongPress 是否被调用
+  UIView *debugView = [[UIView alloc] initWithFrame:CGRectMake(0, 0, 40, 40)];
+  debugView.backgroundColor = [UIColor redColor];
+  debugView.userInteractionEnabled = NO;
+  debugView.tag = 9999;
+  [self addSubview:debugView];
+
+  CGPoint location = [gesture locationInView:self];
+  NSLayoutManager *layoutManager = _textStorage.layoutManagers.firstObject;
+  NSTextContainer *textContainer = layoutManager.textContainers.firstObject;
+
+  if (layoutManager != nil && textContainer != nil && _textStorage.length > 0) {
+    CGFloat fraction;
+    NSUInteger charIndex = [layoutManager characterIndexForPoint:location
+                                                  inTextContainer:textContainer
+                                 fractionOfDistanceBetweenInsertionPoints:&fraction];
+
+    if (charIndex < _textStorage.length) {
+      // 清除旧的高亮
+      [self clearSelectionLayer];
+
+      // 使用 CFStringTokenizer 找到单词边界
+      NSString *text = _textStorage.string;
+      CFRange tokenRange = CFRangeMake(0, text.length);
+      CFLocaleRef locale = CFLocaleCopyCurrent();
+      CFStringTokenizerRef tokenizer = CFStringTokenizerCreate(
+          kCFAllocatorDefault, (__bridge CFStringRef)text, tokenRange, kCFStringTokenizerUnitWord, locale);
+      CFRelease(locale);
+
+      CFStringTokenizerTokenType tokenType = CFStringTokenizerGoToTokenAtIndex(tokenizer, charIndex);
+      if (tokenType != kCFStringTokenizerTokenNone) {
+        CFRange wordCFRange = CFStringTokenizerGetCurrentTokenRange(tokenizer);
+        _selectedRange = NSMakeRange(wordCFRange.location, wordCFRange.length);
+      } else {
+        _selectedRange = NSMakeRange(charIndex, 1);
+      }
+      CFRelease(tokenizer);
+
+      // 使用 NSLayoutManager 计算选中区域 rect，创建 UIView 高亮叠加层
+      if (_selectedRange.location != NSNotFound && _selectedRange.length > 0) {
+        NSRange glyphRange = [layoutManager glyphRangeForCharacterRange:_selectedRange
+                                                   actualCharacterRange:NULL];
+        __block CGRect highlightUnion = CGRectNull;
+        [layoutManager enumerateEnclosingRectsForGlyphRange:glyphRange
+                                    withinSelectedGlyphRange:glyphRange
+                                             inTextContainer:textContainer
+                                                  usingBlock:^(CGRect rect, __unused BOOL *stop) {
+            if (CGRectIsNull(highlightUnion)) {
+              highlightUnion = rect;
+            } else {
+              highlightUnion = CGRectUnion(highlightUnion, rect);
+            }
+          }];
+
+        if (!CGRectIsNull(highlightUnion)) {
+          // 相对于 contentFrame 偏移
+          CGRect highlightFrame = CGRectOffset(CGRectInset(highlightUnion, -2, -2),
+                                               _contentFrame.origin.x,
+                                               _contentFrame.origin.y);
+          UIView *hlView = [[UIView alloc] initWithFrame:highlightFrame];
+          hlView.backgroundColor = [UIColor colorWithRed:1 green:0 blue:0 alpha:0.3];
+          hlView.layer.cornerRadius = 2;
+          hlView.layer.borderColor = [UIColor redColor].CGColor;
+          hlView.layer.borderWidth = 2.0;
+          hlView.userInteractionEnabled = NO;
+          [self addSubview:hlView];
+          _highlightView = hlView;
+        }
+      }
+    }
+  }
+
   if (@available(iOS 16.0, macCatalyst 16.0, *)) {
